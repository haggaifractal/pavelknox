rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions for RBAC
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data : {};
    }

    function getRole() {
      // Prioritize database role for immediate updates, fallback to token claim
      let data = getUserData();
      let dbRole = data.keys().hasAll(['role']) ? data.role : '';
      let claimRole = request.auth.token.get('role', '');
      return dbRole != '' ? dbRole : claimRole;
    }

    function isSuperAdmin() {
      let role = getRole();
      return isAuthenticated() && (
        role == 'superadmin' || 
        // Fallback for primary owner
        request.auth.token.email == 'chagai33@gmail.com'
      );
    }

    function isAdmin() {
      let role = getRole();
      // SuperAdmins also have Admin privileges
      return isAuthenticated() && (
        role == 'admin' || 
        isSuperAdmin()
      );
    }

    function isViewer() {
      let role = getRole();
      // Admins and SuperAdmins also have Viewer privileges
      return isAuthenticated() && (
        role == 'viewer' || 
        isAdmin() ||
        // If they have no role yet, they can't view by default, unless superadmin fallback matched.
        isSuperAdmin()
      );
    }

    // ------------------------------------------------------------------------
    // Granular RBAC Checks from DB
    // ------------------------------------------------------------------------

    function hasPermission(perm) {
      let data = getUserData();
      return data.keys().hasAll(['permissions']) && data.permissions.get(perm, false) == true;
    }

    function canAccessKnowledgeControl() {
      return isAdmin() || hasPermission('canAccessKnowledgeControl');
    }

    function canCreateTasks() {
      return isAdmin() || hasPermission('canCreateTasks');
    }

    function canEditTasks() {
      return isAdmin() || hasPermission('canEditTasks');
    }

    function canDeleteTasks() {
      return isAdmin() || hasPermission('canDeleteTasks');
    }

    function hasDepartmentAccess(resourceData) {
      let data = resourceData;
      let userData = getUserData();
      let userDepts = userData.keys().hasAny(['departmentIds']) ? userData.departmentIds : [];
      // Treat missing visibility as global only for read fallbacks
      let isGlobal = !data.keys().hasAny(['visibilityScope']) || data.visibilityScope == 'global';
      let hasDepts = data.keys().hasAny(['departmentIds']) && data.departmentIds.size() > 0;
      return isGlobal || !hasDepts || (userDepts.hasAny(data.departmentIds));
    }

    function isValidDepartmentAssignment(resourceData, isUpdate) {
      let data = resourceData;
      let isGlobal = data.keys().hasAny(['visibilityScope']) && data.visibilityScope == 'global';
      let userData = getUserData();
      let userDepts = userData.keys().hasAny(['departmentIds']) ? userData.departmentIds : [];
      
      let hasAssignedDepts = data.keys().hasAny(['departmentIds']);
      let assignedDepts = hasAssignedDepts ? data.departmentIds : [];
      
      if (isAdmin()) return true;
      if (isGlobal) return false;
      
      if (hasAssignedDepts) {
        return assignedDepts.size() > 0 && userDepts.hasAll(assignedDepts);
      }
      
      // Prevent maliciously creating department-less tasks to force global visibility.
      // Allow omission ONLY when updating a legacy task that already lacked departments.
      return isUpdate;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    // Inboxes and Drafts: Knowledge Control Center access
    match /raw_inputs/{document=**} {
      allow read: if canAccessKnowledgeControl() && (isSuperAdmin() || hasDepartmentAccess(resource.data));
      allow write: if canAccessKnowledgeControl();
    }

    match /drafts/{document=**} {
      allow read: if canAccessKnowledgeControl() && (isSuperAdmin() || hasDepartmentAccess(resource.data));
      allow write: if canAccessKnowledgeControl();
    }

    // Knowledge Base: Viewable by anyone with access, but only written by Knowledge Control
    match /knowledge_base/{document=**} {
      allow read: if isViewer() && (isSuperAdmin() || hasDepartmentAccess(resource.data));
      allow write: if canAccessKnowledgeControl();
    }

    // Tags: Global metadata dictionary. Readable by viewers, writable by admins.
    match /tags/{document=**} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Tasks: Action items
    match /tasks/{taskId} {
      allow read: if isViewer() && (isSuperAdmin() || hasDepartmentAccess(resource.data));
      allow create: if canCreateTasks() &&
                   isValidDepartmentAssignment(request.resource.data, false) &&
                   (!request.resource.data.keys().hasAny(['title']) || request.resource.data.title.size() <= 100) &&
                   (!request.resource.data.keys().hasAny(['description']) || request.resource.data.description.size() <= 1000);
      allow update: if isViewer() && 
                   (isSuperAdmin() || hasDepartmentAccess(resource.data)) &&
                   isValidDepartmentAssignment(request.resource.data, true) &&
                   (!request.resource.data.keys().hasAny(['title']) || request.resource.data.title.size() <= 100) &&
                   (!request.resource.data.keys().hasAny(['description']) || request.resource.data.description.size() <= 1000);
      allow delete: if canDeleteTasks();

      match /comments/{commentId} {
        allow read: if isViewer();
        allow create: if isViewer() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if canEditTasks() || request.auth.uid == resource.data.authorId;
      }
    }

    // Clients: Global client list. Readable by viewers, writable by admins. Participants can create explicitly from drafts.
    match /clients/{document=**} {
      allow read: if isViewer() && (isSuperAdmin() || hasDepartmentAccess(resource.data));
      allow create: if (isAdmin() || canAccessKnowledgeControl()) &&
                   (!request.resource.data.keys().hasAny(['name']) || request.resource.data.name == null || request.resource.data.name.size() <= 100) &&
                   (!request.resource.data.keys().hasAny(['phone']) || request.resource.data.phone == null || request.resource.data.phone.size() <= 20) &&
                   (!request.resource.data.keys().hasAny(['description']) || request.resource.data.description == null || request.resource.data.description.size() <= 1000) &&
                   (!request.resource.data.keys().hasAny(['budget']) || request.resource.data.budget == null || request.resource.data.budget is number) &&
                   (!request.resource.data.keys().hasAny(['cost']) || request.resource.data.cost == null || request.resource.data.cost is number);
      allow update, delete: if isAdmin() &&
                   (!request.resource.data.keys().hasAny(['name']) || request.resource.data.name == null || request.resource.data.name.size() <= 100) &&
                   (!request.resource.data.keys().hasAny(['phone']) || request.resource.data.phone == null || request.resource.data.phone.size() <= 20) &&
                   (!request.resource.data.keys().hasAny(['description']) || request.resource.data.description == null || request.resource.data.description.size() <= 1000) &&
                   (!request.resource.data.keys().hasAny(['budget']) || request.resource.data.budget == null || request.resource.data.budget is number) &&
                   (!request.resource.data.keys().hasAny(['cost']) || request.resource.data.cost == null || request.resource.data.cost is number);
    }

    // Departments: Organization departments. Readable by viewers, writable by super admins.
    match /departments/{document=**} {
      allow read: if isViewer();
      allow write: if isSuperAdmin();
    }

    // Users: Users can read their own document (to get granular permissions). SuperAdmin can manage all.
    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId;
      allow write: if isSuperAdmin();
    }
  }
}
