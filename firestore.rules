rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Authentication Check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Role Checks via Custom Claims (set by Firebase Admin API)
    function isSuperAdmin() {
      // Legacy users without roles or specific owner email default to superadmin
      return isAuthenticated() && (
        request.auth.token.role == 'superadmin' || 
        request.auth.token.get('role', '') == '' || 
        request.auth.token.email == 'chagai33@gmail.com'
      );
    }

    function isAdmin() {
      // SuperAdmins also have Admin privileges
      return isAuthenticated() && (
        request.auth.token.role == 'admin' || 
        isSuperAdmin()
      );
    }

    function isViewer() {
      // Admins and SuperAdmins also have Viewer privileges
      return isAuthenticated() && (
        request.auth.token.role == 'viewer' || 
        isAdmin()
      );
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    // Inboxes and Drafts: Only Admins can manage raw inputs and drafted records
    match /raw_inputs/{document=**} {
      allow read, write: if isAdmin();
    }

    match /drafts/{document=**} {
      allow read, write: if isAdmin();
    }

    // Knowledge Base: Viewable by anyone with access, but only written by Admins
    match /knowledge_base/{document=**} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Tags: Global metadata dictionary. Readable by viewers, writable by admins.
    match /tags/{document=**} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Tasks: Extracted action items. Readable by viewers, writable by admins.
    match /tasks/{document=**} {
      allow read: if isViewer();
      allow write: if isAdmin() &&
                   (!request.resource.data.keys().hasAny(['title']) || request.resource.data.title.size() <= 100) &&
                   (!request.resource.data.keys().hasAny(['description']) || request.resource.data.description.size() <= 1000);
    }

    // Clients: Global client list. Readable by viewers, writable by admins.
    match /clients/{document=**} {
      allow read: if isViewer();
      allow write: if isAdmin() &&
                   (!request.resource.data.keys().hasAny(['name']) || request.resource.data.name.size() <= 100) &&
                   (!request.resource.data.keys().hasAny(['phone']) || request.resource.data.phone.size() <= 20) &&
                   (!request.resource.data.keys().hasAny(['description']) || request.resource.data.description.size() <= 1000) &&
                   (!request.resource.data.keys().hasAny(['budget']) || request.resource.data.budget is int) &&
                   (!request.resource.data.keys().hasAny(['cost']) || request.resource.data.cost is int);
    }

    // Users: Internal metadata mapping if needed. Strictly SuperAdmin.
    match /users/{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
